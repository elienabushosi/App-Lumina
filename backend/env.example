# SaaS Template Backend – copy to .env.development and .env.production
# Backend loads .env.{NODE_ENV} (development or production)
# Leave placeholders to run locally without connecting services; replace with real values when ready.

# -----------------------------------------------------------------------------
# Supabase (create a project at supabase.com, then Settings → API)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder
SUPABASE_SERVICE_ROLE_KEY=placeholder

# -----------------------------------------------------------------------------
# Resend (email) – leave unset or empty until you connect; app will not send emails
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
RESEND_FROM_EMAIL=SaaS Template <onboarding@resend.dev>
ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Stripe – use test keys in dev; leave empty or placeholder until you connect
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# -----------------------------------------------------------------------------
# RingCentral – from developers.ringcentral.com (My Apps → Create App → REST API App)
# -----------------------------------------------------------------------------
RINGCENTRAL_CLIENT_ID=placeholder
RINGCENTRAL_CLIENT_SECRET=placeholder
# OAuth redirect — must match the URI registered in your RingCentral app
RINGCENTRAL_REDIRECT_URI=http://localhost:3002/api/ringcentral/callback
# Webhook URL for "call ended" — must be publicly reachable (e.g. ngrok: https://YOUR_ID.ngrok.io/api/ringcentral/webhook)
# RINGCENTRAL_WEBHOOK_URL=https://YOUR_ID.ngrok.io/api/ringcentral/webhook
# Optional: https://platform.ringcentral.com (production) or https://platform.devtest.ringcentral.com (sandbox)
# RINGCENTRAL_SERVER_URL=https://platform.devtest.ringcentral.com
# For backend/sample.js ring-out only: JWT token and caller/recipient numbers
# RINGCENTRAL_JWT_TOKEN=
# RINGOUT_CALLER=+18186969121
# RECIPIENT_NUMBER=2147100953

# -----------------------------------------------------------------------------
# Server & frontend
# -----------------------------------------------------------------------------
PORT=3002
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Geo / external APIs – optional; leave placeholder if not using these features
# -----------------------------------------------------------------------------
GEOSERVICE_API_KEY=placeholder
